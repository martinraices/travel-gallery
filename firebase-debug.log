[debug] [2026-05-10T02:47:30.373Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/wanderlust-gallery/rulesets {"name":"projects/wanderlust-gallery/rulesets/31c796bc-1d61-408a-821b-c03804e653c5","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice firebase.storage {\r\n  match /b/{bucket}/o {\r\n    function isAdmin() {\r\n      return request.auth != null &&\r\n        request.auth.token.email in ['raicesm@gmail.com', 'elena.beccaro@gmail.com'];\r\n    }\r\n\r\n    function isOwner(userId) {\r\n      return request.auth != null && request.auth.uid == userId;\r\n    }\r\n\r\n    match /users/{userId}/{allPaths=**} {\n      allow read: if isAdmin() || isOwner(userId);\n      allow write: if isOwner(userId);\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-05-10T02:47:30.151551Z","metadata":{"services":["firebase.storage"]}}
