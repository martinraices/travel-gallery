[debug] [2026-05-10T02:47:32.421Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/wanderlust-gallery/rulesets {"name":"projects/wanderlust-gallery/rulesets/a9cbbc7b-9d0c-4a30-80a8-37af27018d0c","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function isAdmin() {\r\n      return request.auth != null &&\r\n        request.auth.token.email == 'raicesm@gmail.com';\r\n    }\r\n\r\n    function signedInEmail() {\r\n      return request.auth != null ? request.auth.token.email : null;\r\n    }\r\n\r\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isTripOwner(trip) {\n      return request.auth != null &&\n        (trip.ownerId == request.auth.uid || !('ownerId' in trip));\n    }\n\n    function hasTripAccess(trip) {\r\n      return trip.visibility == 'shared' || (\r\n        request.auth != null && (\r\n          trip.ownerId == request.auth.uid ||\r\n          !('ownerId' in trip) ||\r\n          isAdmin() ||\r\n          (signedInEmail() != null &&\r\n           'allowedEmails' in trip &&\r\n           signedInEmail() in trip.allowedEmails)\r\n        )\r\n      );\r\n    }\r\n\r\n    function validTripCreate() {\n      return request.resource.data.ownerId == request.auth.uid &&\n        request.resource.data.ownerEmail == signedInEmail() &&\n        request.resource.data.visibility in ['shared', 'private'];\n    }\n\n    function validTripUpdate() {\n      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerId', 'ownerEmail']) &&\n        request.resource.data.visibility in ['shared', 'private'];\n    }\n\r\n    function validShareLink() {\r\n      return request.resource.data.keys().hasOnly([\r\n        'tripId', 'ownerId', 'tripName', 'tripDate', 'photos', 'expiresAt', 'createdAt'\r\n      ]) &&\r\n      request.resource.data.tripName is string &&\r\n      request.resource.data.photos is list;\r\n    }\r\n\r\n    // Trips: public can read shared trips; owners, admins and email-granted users can read private trips.\r\n    match /trips/{tripId} {\n      allow read: if hasTripAccess(resource.data);\n      allow create: if isSignedIn() && validTripCreate();\n      allow update: if isAdmin() || (isTripOwner(resource.data) && validTripUpdate());\n      allow delete: if isAdmin() || isTripOwner(resource.data);\n    }\n\n    // Photos follow their parent trip visibility/access rules.\n    match /trips/{tripId}/photos/{photoId} {\n      allow read: if hasTripAccess(get(/databases/$(database)/documents/trips/$(tripId)).data);\n      allow write: if isAdmin() ||\n        isTripOwner(get(/databases/$(database)/documents/trips/$(tripId)).data);\n    }\n\r\n    match /trips/{tripId}/photos/{photoId}/faces/{faceId} {\r\n      allow read: if isSignedIn();\r\n      allow write: if false;\r\n    }\r\n\r\n    match /people/{personId} {\r\n      allow read: if isSignedIn();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    match /people/{personId}/matches/{matchId} {\r\n      allow read: if isSignedIn();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    match /faceIndex/{faceId} {\r\n      allow read: if isSignedIn();\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Per-user data (wishlist, etc.) is private.\r\n    match /users/{userId}/{document=**} {\r\n      allow read: if request.auth != null && request.auth.uid == userId;\r\n      allow write: if request.auth != null && request.auth.uid == userId;\r\n    }\r\n\r\n    // Public profiles: authenticated users can read email/displayName for creator attribution.\r\n    match /profiles/{userId} {\r\n      allow read: if request.auth != null;\r\n      allow write: if isAdmin();\r\n    }\r\n\r\n    // Shared links are intentionally public by token; only admins can create/update/delete them.\r\n    match /sharedLinks/{token} {\r\n      allow read: if true;\r\n      allow create: if isAdmin() && validShareLink();\r\n      allow update: if isAdmin() && validShareLink();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // Album shares are admin-only.\r\n    match /albumShares/{shareId} {\r\n      allow read, write: if isAdmin();\r\n    }\r\n\r\n    // Access requests: any signed-in Gmail user may create/read their own request; admins review all.\r\n    match /accessRequests/{email} {\r\n      allow create, update: if request.auth != null &&\r\n        email == signedInEmail() &&\r\n        request.resource.data.email == signedInEmail() &&\r\n        request.resource.data.status == 'pending';\r\n      allow read: if isAdmin() || (request.auth != null && email == signedInEmail());\r\n      allow delete: if isAdmin();\r\n      allow update: if isAdmin();\r\n    }\r\n\r\n    // Global settings (panel label etc.): authenticated users can read; only admins can write.\r\n    match /globalSettings/{docId} {\r\n      allow read: if request.auth != null;\r\n      allow write: if isAdmin();\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-05-10T02:47:32.156303Z","metadata":{"services":["cloud.firestore"]}}
