rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['raicesm@gmail.com', 'elena.beccaro@gmail.com'];
    }

    function signedInEmail() {
      return request.auth != null ? request.auth.token.email : null;
    }

    function hasTripAccess(trip) {
      return trip.visibility == 'shared' || (
        request.auth != null && (
          trip.ownerId == request.auth.uid ||
          !('ownerId' in trip) ||
          isAdmin() ||
          (signedInEmail() != null &&
           'allowedEmails' in trip &&
           signedInEmail() in trip.allowedEmails)
        )
      );
    }

    function validTripCreate() {
      return request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.ownerEmail == signedInEmail() &&
        request.resource.data.visibility in ['shared', 'private'];
    }

    function validShareLink() {
      return request.resource.data.keys().hasOnly([
        'tripId', 'ownerId', 'tripName', 'tripDate', 'photos', 'expiresAt', 'createdAt'
      ]) &&
      request.resource.data.tripName is string &&
      request.resource.data.photos is list;
    }

    // Trips: public can read shared trips; owners, admins and email-granted users can read private trips.
    match /trips/{tripId} {
      allow read: if hasTripAccess(resource.data);
      allow create: if isAdmin() && validTripCreate();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Photos follow their parent trip visibility/access rules.
    match /trips/{tripId}/photos/{photoId} {
      allow read: if hasTripAccess(get(/databases/$(database)/documents/trips/$(tripId)).data);
      allow write: if isAdmin();
    }

    // Per-user data (wishlist, etc.) is private.
    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin() && request.auth.uid == userId;
    }

    // Public profiles: authenticated users can read email/displayName for creator attribution.
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() && request.auth.uid == userId;
    }

    // Shared links are intentionally public by token; only admins can create/update/delete them.
    match /sharedLinks/{token} {
      allow read: if true;
      allow create: if isAdmin() && validShareLink();
      allow update: if isAdmin() && validShareLink();
      allow delete: if isAdmin();
    }

    // Album shares are admin-only.
    match /albumShares/{shareId} {
      allow read, write: if isAdmin();
    }

    // Access requests: any signed-in Gmail user may create/read their own request; admins review all.
    match /accessRequests/{email} {
      allow create, update: if request.auth != null &&
        email == signedInEmail() &&
        request.resource.data.email == signedInEmail() &&
        request.resource.data.status == 'pending';
      allow read: if isAdmin() || (request.auth != null && email == signedInEmail());
      allow delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Global settings (panel label etc.): authenticated users can read; only admins can write.
    match /globalSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
