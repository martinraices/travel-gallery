rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Trips: owner can always read/write; others can only read shared trips
    match /trips/{tripId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'shared' ||
        resource.data.ownerId == request.auth.uid ||
        !('ownerId' in resource.data)  // legacy trips without ownerId are visible to all
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // Photos: access mirrors the parent trip's visibility
    match /trips/{tripId}/photos/{photoId} {
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/trips/$(tripId)).data.visibility == 'shared' ||
        get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
        !('ownerId' in get(/databases/$(database)/documents/trips/$(tripId)).data)
      );
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid;
    }

    // Per-user data (wishlist, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared links are publicly readable; only authenticated users can create/delete them
    match /sharedLinks/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
