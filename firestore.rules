rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Trips: owner can always read/write; others can read shared trips or trips shared with their email
    match /trips/{tripId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'shared' ||
        resource.data.ownerId == request.auth.uid ||
        !('ownerId' in resource.data) ||
        (request.auth.token.email != null &&
         'allowedEmails' in resource.data &&
         request.auth.token.email in resource.data.allowedEmails)
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        // Any authenticated user can patch cover or ownerEmail on shared trips
        (resource.data.visibility == 'shared' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cover', 'ownerEmail']))
      );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // Photos: any authenticated user can read/write (trip-level rules enforce ownership)
    match /trips/{tripId}/photos/{photoId} {
      allow read, write: if request.auth != null;
    }

    // Per-user data (wishlist, etc.) — private
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public profiles — any authenticated user can read email/displayName for creator attribution
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared links are publicly readable; only authenticated users can create/delete them
    match /sharedLinks/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Album shares — authenticated users can read/write (admin-only in practice via app logic)
    match /albumShares/{shareId} {
      allow read, write: if request.auth != null;
    }

    // Global settings (panel label etc.) — any authenticated user can read; only admins can write
    match /globalSettings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in ['raicesm@gmail.com', 'elena.beccaro@gmail.com'];
    }
  }
}
