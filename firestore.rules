rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Trips: owner can always read/write; others can only read shared trips
    match /trips/{tripId} {
      allow read: if request.auth != null && (
        resource.data.visibility == 'shared' ||
        resource.data.ownerId == request.auth.uid ||
        !('ownerId' in resource.data)  // legacy trips without ownerId are visible to all
      );
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        // Any authenticated user can patch only the cover field on shared trips
        (resource.data.visibility == 'shared' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cover']))
      );
      allow delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;
    }

    // Photos: any authenticated user can read/write (trip-level rules enforce ownership)
    match /trips/{tripId}/photos/{photoId} {
      allow read, write: if request.auth != null;
    }

    // Per-user data (wishlist, etc.) — private
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public profiles — any authenticated user can read email/displayName for creator attribution
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared links are publicly readable; only authenticated users can create/delete them
    match /sharedLinks/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
